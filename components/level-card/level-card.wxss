.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.card.completed {
  background: #f0f9f0;
}

.level-number {
  width: 60rpx;
  height: 60rpx;
  background: #4caf50;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.card.completed .level-number {
  background: #8bc34a;
}

.level-info {
  flex: 1;
  margin-left: 20rpx;
}

.level-name {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.level-type {
  font-size: 24rpx;
  color: #666;
}

.level-status {
  margin-left: 20rpx;
}

.status-text {
  font-size: 26rpx;
  color: #4caf50;
}

.status-text.pending {
  color: #999;
}