.quiz-choice {
  padding: 10rpx 0;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option {
  display: flex;
  align-items: center;
  padding: 25rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 3rpx solid transparent;
}

.option.selected {
  background: #e8f5e9;
  border-color: #4caf50;
}

.option-marker {
  width: 48rpx;
  height: 48rpx;
  background: #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.option.selected .option-marker {
  background: #4caf50;
  color: #fff;
}

.option-text {
  font-size: 30rpx;
  flex: 1;
}