<view class="quiz-sort">
  <view class="hint">点击选项添加到排序中</view>

  <view class="selected-area" wx:if="{{orderedItems.length > 0}}">
    <text class="area-label">已排序:</text>
    <view class="selected-items">
      <block wx:for="{{orderedItems}}" wx:key="value">
        <view class="item selected-item">{{item.label}}</view>
      </block>
    </view>
  </view>

  <view class="available-items">
    <block wx:for="{{items}}" wx:key="value">
      <view class="item available-item" bindtap="onItemTap" data-index="{{index}}">
        <text>{{item.label}}</text>
      </view>
    </block>
  </view>

  <button class="btn-reset" bindtap="onReset">重置</button>
</view>