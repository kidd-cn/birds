.quiz-sort {
  padding: 10rpx 0;
}

.hint {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.selected-area {
  background: #e8f5e9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.area-label {
  font-size: 26rpx;
  color: #4caf50;
  display: block;
  margin-bottom: 15rpx;
}

.selected-items {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.item {
  padding: 15rpx 30rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.selected-item {
  background: #4caf50;
  color: #fff;
}

.available-items {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.available-item {
  background: #f5f5f5;
  color: #333;
}

.btn-reset {
  margin-top: 20rpx;
  width: 200rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: #fff;
  border: 2rpx solid #ddd;
  border-radius: 30rpx;
  font-size: 26rpx;
}