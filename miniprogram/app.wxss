/**
 * 深圳观鸟助手 — 全局主题
 * 浅灰页面底 + 白色卡片 + 深灰文字
 */

page {
  /* 湿地浅绿：呼应红树林、候鸟驿站等观鸟场景 */
  --bg-page: #e8f4ec;
  --bg-card: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-muted: #999999;
  --border-light: #eeeeee;
  --shadow-card: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  --radius-card: 15rpx;

  background-color: var(--bg-page);
  color: var(--text-primary);
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 地图相关样式 */
.map-container {
  width: 100%;
  height: 100vh;
}

/* 鸟类详情弹窗样式 */
.bird-detail-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 70%;
  background-color: var(--bg-card);
  border-top-left-radius: var(--radius-card);
  border-top-right-radius: var(--radius-card);
  padding: 30rpx;
  box-shadow: var(--shadow-card);
  z-index: 1000;
}

.bird-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.bird-detail-close {
  font-size: 36rpx;
  color: var(--text-muted);
}

.bird-detail-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  flex-grow: 1;
  color: var(--text-primary);
}

.bird-image {
  width: 100%;
  height: 300rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.bird-info {
  margin-top: 20rpx;
}

.bird-name {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: var(--text-primary);
}

.bird-scientific-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.bird-description {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 按钮样式 */
.button {
  margin: 20rpx 0;
  padding: 20rpx;
  background-color: #007aff;
  color: white;
  border-radius: 10rpx;
  text-align: center;
}
