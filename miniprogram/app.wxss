/**
 * 全局样式
 */

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

/* 地图相关样式 */
.map-container {
  width: 100%;
  height: 100vh;
}

/* 鸟类详情弹窗样式 */
.bird-detail-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 70%;
  background-color: white;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 -10rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 1000;
}

.bird-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.bird-detail-close {
  font-size: 36rpx;
  color: #999;
}

.bird-detail-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  flex-grow: 1;
}

.bird-image {
  width: 100%;
  height: 300rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.bird-info {
  margin-top: 20rpx;
}

.bird-name {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.bird-scientific-name {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.bird-description {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 按钮样式 */
.button {
  margin: 20rpx 0;
  padding: 20rpx;
  background-color: #007AFF;
  color: white;
  border-radius: 10rpx;
  text-align: center;
}