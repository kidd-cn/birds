<!-- Bird Identification Game Component -->
<view class="bird-game-container">
  <view class="game-header">
    <text class="score-text">Score: {{score}}</text>
    <text class="question-num">Question: {{questionNumber}}/{{totalQuestions}}</text>
  </view>

  <view class="difficulty-selector" wx:if="{{!gameStarted}}">
    <text class="difficulty-title">Select Difficulty:</text>
    <view class="difficulty-buttons">
      <button class="difficulty-btn {{difficulty === 1 ? 'selected' : ''}}" data-difficulty="1" bindtap="selectDifficulty">Easy</button>
      <button class="difficulty-btn {{difficulty === 2 ? 'selected' : ''}}" data-difficulty="2" bindtap="selectDifficulty">Medium</button>
      <button class="difficulty-btn {{difficulty === 3 ? 'selected' : ''}}" data-difficulty="3" bindtap="selectDifficulty">Hard</button>
      <button class="difficulty-btn {{difficulty === 4 ? 'selected' : ''}}" data-difficulty="4" bindtap="selectDifficulty">Expert</button>
      <button class="difficulty-btn {{difficulty === 5 ? 'selected' : ''}}" data-difficulty="5" bindtap="selectDifficulty">Master</button>
    </view>
    <button class="start-btn" bindtap="startGame" disabled="{{difficulty === 0}}">Start Game</button>
  </view>

  <view class="game-content" wx:if="{{gameStarted && !gameCompleted}}">
    <view class="bird-image-container">
      <image
        src="{{currentQuestion.imageUrl}}"
        class="bird-image"
        mode="aspectFit"
        style="{{getImageStyle()}}"
        binderror="onImageError"
      ></image>
      <view class="progress-indicator">
        <text>{{questionNumber}} / {{totalQuestions}}</text>
      </view>
    </view>

    <view class="options-container">
      <view
        class="option-item {{selectedOptionIndex === index ? 'selected' : ''}} {{showResult && index === currentQuestion.correctAnswerIndex ? 'correct' : ''}} {{showResult && index === selectedOptionIndex && index !== currentQuestion.correctAnswerIndex ? 'incorrect' : ''}}"
        wx:for="{{currentQuestion.options}}"
        wx:key="index"
        data-index="{{index}}"
        bindtap="selectOption"
      >
        <text class="option-text">{{item}}</text>
      </view>
    </view>

    <view class="feedback-container" wx:if="{{showResult}}">
      <text class="feedback-text {{isCorrect ? 'correct-text' : 'incorrect-text'}}">
        {{isCorrect ? 'Correct!' : 'Incorrect!'}}
      </text>
      <text class="bird-info">The bird is: {{currentQuestion.correctAnswer}}</text>
      <button class="next-btn" bindtap="nextQuestion">{{questionNumber >= totalQuestions ? 'Finish Game' : 'Next Question'}}</button>
    </view>
  </view>

  <view class="game-result" wx:if="{{gameCompleted}}">
    <view class="final-score-container">
      <text class="final-score-title">Game Completed!</text>
      <text class="final-score">Final Score: {{score}}</text>
      <text class="performance">Performance: {{getPerformanceMessage()}}</text>
    </view>
    <button class="restart-btn" bindtap="restartGame">Play Again</button>
  </view>
</view>