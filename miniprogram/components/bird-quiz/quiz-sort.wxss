/* Quiz Sort Component Styles */

.quiz-sort-container {
  width: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.instruction-area {
  margin-bottom: 24rpx;
  padding: 16rpx 24rpx;
  background: #e3f2fd;
  border-radius: 12rpx;
}

.instruction-text {
  display: block;
  font-size: 26rpx;
  color: #1976d2;
  text-align: center;
}

.sort-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sort-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx solid #e0e0e0;
  transition: all 0.3s ease;
}

.sort-item:not(.locked):active {
  background: #e0e0e0;
  transform: scale(0.98);
}

.sort-item.locked {
  background: #fafafa;
  border-color: #bdbdbd;
  opacity: 0.8;
}

.item-index {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #2196f3;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.sort-item.locked .item-index {
  background: #9e9e9e;
}

.item-text {
  flex: 1;
  font-size: 28rpx;
  color: #424242;
  line-height: 1.4;
}

.drag-hint {
  padding: 0 12rpx;
}

.hint-icon {
  font-size: 28rpx;
  color: #9e9e9e;
}

.action-area {
  margin-top: 32rpx;
}

.confirm-button {
  width: 100%;
  padding: 24rpx;
  background: #4caf50;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.next-button {
  width: 100%;
  padding: 24rpx;
  background: #2196f3;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}