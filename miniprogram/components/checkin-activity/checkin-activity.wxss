/* miniprogram/components/checkin-activity/checkin-activity.wxss */

.checkin-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.progress-section {
  background: white;
  padding: 30rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.progress-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.progress-bar-container {
  width: 100%;
  height: 20rpx;
  background-color: #e0e0e0;
  border-radius: 10rpx;
  overflow: hidden;
  margin: 20rpx 0;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4caf50, #8bc34a);
  transition: width 0.5s ease;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

.badge-awarded-notification {
  position: fixed;
  top: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #4caf50;
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  z-index: 1000;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    top: -100rpx;
    opacity: 0;
  }
  to {
    top: 100rpx;
    opacity: 1;
  }
}

.notification-text {
  font-size: 28rpx;
  font-weight: bold;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  margin: 30rpx 0 20rpx;
}

.spots-list {
  margin-bottom: 30rpx;
}

.spot-card {
  background: white;
  border-radius: 15rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.spot-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.spot-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  border-radius: 50%;
}

.spot-info {
  flex: 1;
}

.spot-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.spot-location {
  display: block;
  font-size: 26rpx;
  color: #7f8c8d;
  margin-top: 5rpx;
}

.spot-details {
  margin: 15rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.spot-description {
  font-size: 26rpx;
  color: #34495e;
  flex: 1;
}

.spot-difficulty {
  padding: 8rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: white;
}

.difficulty-easy {
  background-color: #4caf50;
}

.difficulty-moderate {
  background-color: #ff9800;
}

.difficulty-hard {
  background-color: #f44336;
}

.bird-species {
  margin: 15rpx 0;
}

.species-label {
  display: block;
  font-size: 26rpx;
  color: #7f8c8d;
  margin-bottom: 10rpx;
  font-style: italic;
}

.species-list {
  display: flex;
  flex-wrap: wrap;
}

.species-item {
  background-color: #ecf0f1;
  color: #34495e;
  padding: 8rpx 15rpx;
  border-radius: 15rpx;
  font-size: 24rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.checkin-btn {
  width: 100%;
  background-color: #3498db;
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-top: 20rpx;
}

.checkin-btn.checked-in {
  background-color: #2ecc71;
}

.checkin-btn.not-checked {
  background-color: #3498db;
}

.checkin-btn:disabled {
  background-color: #bdc3c7;
}

.badges-section {
  background: white;
  border-radius: 15rpx;
  padding: 25rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.badges-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200rpx, 1fr));
  gap: 20rpx;
}

.badge-item {
  display: flex;
  justify-content: center;
}

.badge-inner {
  width: 100%;
  padding: 20rpx;
  border-radius: 15rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.earned-badge {
  background-color: #e8f5e9;
  border: 2rpx solid #4caf50;
}

.unearned-badge {
  background-color: #f5f5f5;
  border: 2rpx dashed #bdc3c7;
}

.badge-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.badge-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 5rpx;
}

.badge-status {
  font-size: 22rpx;
  color: #7f8c8d;
  margin-bottom: 5rpx;
}

.badge-desc {
  font-size: 20rpx;
  color: #95a5a6;
  text-align: center;
}