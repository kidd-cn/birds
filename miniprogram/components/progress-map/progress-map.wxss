.progress-map {
  width: 100%;
  background: linear-gradient(180deg, #e8f5e9 0%, #c8e6c9 100%);
  border-radius: 24rpx;
  overflow: hidden;
}

.map-background {
  display: none;
}

.topics-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx;
}

.topic-node {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 3rpx solid transparent;
}

.topic-node.locked {
  opacity: 0.6;
}

.topic-node.unlocked {
  border-color: #ffc107;
}

.topic-node.completed {
  border-color: #4caf50;
}

.node-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.node-content {
  flex: 1;
}

.node-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.node-progress {
  font-size: 22rpx;
  color: #888;
}

.node-status {
  font-size: 36rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.progress-info {
  text-align: center;
  padding: 30rpx 20rpx;
}

.total-progress {
  font-size: 26rpx;
  color: #666;
}