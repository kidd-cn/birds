.progress-map {
  position: relative;
  width: 100%;
  height: 900rpx;
  background: linear-gradient(180deg, #e8f5e9 0%, #c8e6c9 100%);
  border-radius: 24rpx;
  overflow: hidden;
}

.map-background {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.3;
}

.bg-path {
  width: 100%;
  height: 100%;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 800"><path d="M50 400 Q200 200 350 400 T200 700" stroke="%232e8b57" fill="none" stroke-width="3" stroke-dasharray="10,10"/></svg>') no-repeat center;
  background-size: cover;
}

.topics-container {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
}

.topic-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
  width: 240rpx;
  position: absolute;
}

.topic-node.locked {
  opacity: 0.6;
  filter: grayscale(30%);
}

.topic-node.unlocked {
  border: 3rpx solid #ffc107;
}

.topic-node.completed {
  border: 3rpx solid #4caf50;
}

.node-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.node-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
  text-align: center;
}

.node-progress {
  font-size: 20rpx;
  color: #888;
}

.node-badge {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  font-size: 36rpx;
  background: #fff;
  border-radius: 50%;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.connection-lines {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.line {
  position: absolute;
  width: 4rpx;
  background: #2e8b57;
  opacity: 0.25;
}

.line-1 { top: 160rpx; left: 50%; height: 120rpx; transform: translateX(-50%); }
.line-2 { top: 380rpx; left: 50%; height: 120rpx; transform: translateX(-50%); }
.line-3 { top: 600rpx; left: 50%; height: 120rpx; transform: translateX(-50%); }

.progress-info {
  position: absolute;
  bottom: 30rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.total-progress {
  font-size: 24rpx;
  color: #666;
  background: rgba(255,255,255,0.8);
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  display: inline-block;
}