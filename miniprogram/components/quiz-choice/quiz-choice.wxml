<!-- Quiz Choice Component -->
<view class="quiz-choice-container">
  <!-- Question Text -->
  <view class="question-section">
    <text class="question-text">{{question.text}}</text>
  </view>

  <!-- Options List -->
  <view class="options-container">
    <block wx:for="{{question.options}}" wx:key="id">
      <view
        class="option-item {{answered ? (item.isCorrect ? 'correct' : (selectedOption === item.id ? 'incorrect' : '')) : (selectedOption === item.id ? 'selected' : '')}}"
        data-option="{{item.id}}"
        bindtap="onOptionTap"
      >
        <view class="option-id">{{item.id + 1}}</view>
        <text class="option-text">{{item.text}}</text>
      </view>
    </block>
  </view>

  <!-- Explanation -->
  <block wx:if="{{showExplanation && question.explanation}}">
    <view class="explanation-area">
      <text class="explanation-title">解释:</text>
      <text class="explanation-text">{{question.explanation}}</text>
    </view>
  </block>

  <!-- Next Button -->
  <block wx:if="{{answered}}">
    <button class="next-button" bindtap="onNext">下一题</button>
  </block>
</view>