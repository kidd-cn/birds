/* Quiz Choice Component Styles */

.quiz-choice-container {
  width: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.question-section {
  margin-bottom: 32rpx;
}

.question-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  line-height: 1.5;
}

.options-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item.selected {
  background: #e3f2fd;
  border-color: #2196f3;
}

.option-item.correct {
  background: #e8f5e9;
  border-color: #4caf50;
}

.option-item.incorrect {
  background: #ffebee;
  border-color: #f44336;
}

.option-id {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #e0e0e0;
  color: #616161;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.option-item.correct .option-id {
  background: #4caf50;
  color: #fff;
}

.option-item.incorrect .option-id {
  background: #f44336;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #424242;
  line-height: 1.4;
}

.result-icon {
  font-size: 24rpx;
  color: #4caf50;
  margin-left: 16rpx;
  font-weight: bold;
}

.result-icon-wrong {
  font-size: 24rpx;
  color: #f44336;
  margin-left: 16rpx;
  font-weight: bold;
}

/* Feedback Area */
.feedback-area {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.feedback-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.feedback-item:last-child {
  margin-bottom: 0;
}

.feedback-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 12rpx;
}

.feedback-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.feedback-status {
  margin-left: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.correct-text {
  color: #4caf50;
}

.wrong-text {
  color: #f44336;
}

.correct-answer .feedback-value {
  color: #4caf50;
}

/* Explanation Area */
.explanation-area {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #fff8e1;
  border-radius: 16rpx;
  border-left: 8rpx solid #ffc107;
}

.explanation-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #f57c00;
  margin-bottom: 8rpx;
}

.explanation-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.next-button {
  margin-top: 32rpx;
  padding: 24rpx 48rpx;
  background: #2e8b57;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}