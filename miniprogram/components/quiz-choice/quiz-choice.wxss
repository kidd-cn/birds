/* Quiz Choice Component Styles */

.quiz-choice-container {
  width: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.question-section {
  margin-bottom: 32rpx;
}

.question-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  line-height: 1.5;
}

.options-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item.selected {
  background: #e3f2fd;
  border-color: #2196f3;
}

.option-item.correct {
  background: #e8f5e9;
  border-color: #4caf50;
}

.option-item.incorrect {
  background: #ffebee;
  border-color: #f44336;
}

.option-id {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #e0e0e0;
  color: #616161;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.option-item.correct .option-id {
  background: #4caf50;
  color: #fff;
}

.option-item.incorrect .option-id {
  background: #f44336;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #424242;
  line-height: 1.4;
}

.explanation-area {
  margin-top: 32rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border-left: 8rpx solid #2196f3;
}

.explanation-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1976d2;
  margin-bottom: 8rpx;
}

.explanation-text {
  display: block;
  font-size: 26rpx;
  color: #616161;
  line-height: 1.5;
}

.next-button {
  margin-top: 32rpx;
  padding: 24rpx 48rpx;
  background: #2196f3;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}