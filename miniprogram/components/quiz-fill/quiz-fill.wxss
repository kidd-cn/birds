/* Quiz Fill Component Styles */

.quiz-fill-container {
  width: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.question-section {
  margin-bottom: 32rpx;
}

.question-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
  line-height: 1.5;
}

.fill-area {
  margin-bottom: 24rpx;
}

.input-wrapper {
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx solid #e0e0e0;
  transition: all 0.3s ease;
}

.input-wrapper.correct {
  background: #e8f5e9;
  border-color: #4caf50;
}

.input-wrapper.incorrect {
  background: #ffebee;
  border-color: #f44336;
}

.fill-input {
  width: 100%;
  font-size: 28rpx;
  color: #424242;
  background: transparent;
  border: none;
  outline: none;
}

.result-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.result-area.correct {
  background: #e8f5e9;
}

.result-area.incorrect {
  background: #ffebee;
}

.result-icon {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.result-area.correct .result-icon {
  color: #4caf50;
}

.result-area.incorrect .result-icon {
  color: #f44336;
}

.result-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #424242;
}

.correct-answer {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #616161;
}

.action-area {
  margin-top: 24rpx;
}

.confirm-button {
  width: 100%;
  padding: 24rpx;
  background: #4caf50;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.next-button {
  width: 100%;
  padding: 24rpx;
  background: #2196f3;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}