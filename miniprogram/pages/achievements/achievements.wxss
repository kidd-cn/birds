.container {
  padding: 0;
  background: linear-gradient(180deg, #e8f5e9 0%, #f0f8f4 100%);
  min-height: 100vh;
}

/* 顶部Banner */
.top-banner {
  background: linear-gradient(135deg, #2e8b57, #4caf50);
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.banner-content {
  flex: 1;
}

.banner-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.banner-decoration {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-icon {
  font-size: 56rpx;
}

/* 称号卡片 */
.title-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.title-badge-large {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #ffc107, #ff9800);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.title-icon {
  font-size: 56rpx;
}

.title-details {
  flex: 1;
}

.user-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.title-badges {
  display: flex;
  gap: 12rpx;
  margin-top: 10rpx;
}

.title-badge-item {
  background: #f0f8f4;
  color: #2e8b57;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.score-section {
  text-align: center;
  padding-left: 24rpx;
  border-left: 2rpx solid #eee;
}

.score-number-large {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffc107;
  display: block;
}

.score-unit {
  font-size: 22rpx;
  color: #888;
  display: block;
}

/* 通用卡片样式 */
.progress-card,
.badge-card,
.rank-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.card-count {
  font-size: 24rpx;
  color: #888;
}

/* 学习进度 */
.progress-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-ring {
  display: flex;
  align-items: baseline;
  justify-content: center;
  background: #f0f8f4;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #2e8b57;
}

.stat-max {
  font-size: 22rpx;
  color: #888;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
}

/* 进度条 */
.progress-bar-section {
  margin-top: 10rpx;
}

.progress-bar-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.progress-bar-title {
  font-size: 24rpx;
  color: #666;
}

.progress-bar-percent {
  font-size: 24rpx;
  font-weight: bold;
  color: #2e8b57;
}

.progress-bar {
  height: 16rpx;
  background: #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #2e8b57, #4caf50);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

/* 徽章墙 */
.badge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.badge-item {
  width: 30%;
  background: linear-gradient(135deg, #fff8e1, #fff3cd);
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  position: relative;
  border: 2rpx solid #ffc107;
}

.badge-icon-box {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.badge-icon {
  font-size: 48rpx;
}

.badge-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.badge-desc {
  font-size: 18rpx;
  color: #888;
}

.badge-glow {
  position: absolute;
  top: -5rpx;
  right: -5rpx;
  width: 30rpx;
  height: 30rpx;
  background: #ffc107;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

/* 空状态 */
.empty-badges {
  text-align: center;
  padding: 60rpx 40rpx;
}

.empty-icon-box {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #888;
}

/* 称号预览 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.rank-item.active {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
}

.rank-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.rank-name {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.rank-status {
  font-size: 28rpx;
  color: #4caf50;
  font-weight: bold;
}

/* 海报按钮 */
.poster-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ffc107, #ff9800);
  color: #fff;
  border-radius: 50rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  margin: 30rpx 20rpx 20rpx;
}

.poster-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

/* 海报 Canvas */
.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 600rpx;
  height: 800rpx;
}