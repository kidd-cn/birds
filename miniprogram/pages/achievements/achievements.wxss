/* pages/achievements/achievements.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2e8b57;
}

.achievements-list {
  margin-bottom: 40rpx;
}

.achievement-card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.achievement-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #e8f5e9;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
}

.icon {
  font-size: 36rpx;
}

.achievement-content {
  flex: 1;
}

.achievement-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.achievement-description {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.achievement-status {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.achievement-status.unlocked {
  background-color: #4caf50;
  color: white;
}

.achievement-status.locked {
  background-color: #ccc;
  color: white;
}

.no-achievements {
  text-align: center;
  padding: 80rpx 20rpx;
  color: #999;
  font-size: 28rpx;
}