.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #e8f5e9 0%, #f0f8f4 100%);
  min-height: 100vh;
}

/* 头部装饰 */
.header-decoration {
  text-align: center;
  padding: 30rpx 0 10rpx;
}

.header-icon {
  font-size: 80rpx;
  display: inline-block;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.header {
  text-align: center;
  padding-bottom: 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #2e8b57;
  display: block;
}

/* 称号卡片 */
.title-card {
  background: linear-gradient(135deg, #2e8b57, #4caf50);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.3);
}

.title-badge {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.title-icon {
  font-size: 56rpx;
}

.title-info {
  flex: 1;
}

.user-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.title-level {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
  display: block;
}

.score-display {
  text-align: center;
  padding-left: 24rpx;
  border-left: 2rpx solid rgba(255, 255, 255, 0.3);
}

.score-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* 进度概览 */
.progress-overview {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.progress-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.progress-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #2e8b57;
}

.progress-label {
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
}

.progress-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e0e0e0;
}

/* 徽章墙 */
.badge-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-count {
  font-size: 24rpx;
  color: #888;
}

.badge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
  padding: 20rpx 10rpx;
  background: linear-gradient(135deg, #fff8e1, #ffecb3);
  border-radius: 16rpx;
  border: 2rpx solid #ffc107;
}

.badge-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.badge-icon {
  font-size: 48rpx;
}

.badge-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 4rpx;
}

.badge-desc {
  font-size: 18rpx;
  color: #888;
  text-align: center;
}

/* 空状态 */
.empty-badges {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #888;
}

/* 徽章图例 */
.badge-legend {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.legend-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.legend-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.legend-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.legend-name {
  font-size: 22rpx;
  color: #666;
}

/* 海报按钮 */
.poster-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2e8b57;
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 40rpx;
  font-size: 28rpx;
  border: none;
  margin-top: 10rpx;
}

.poster-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

/* 海报 Canvas */
.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 600rpx;
  height: 800rpx;
}