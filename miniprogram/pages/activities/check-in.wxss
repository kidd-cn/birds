/* pages/activities/check-in.wxss */
.container {
  padding: 20px;
  min-height: 100vh;
  background: linear-gradient(135deg, #2e8b57 0%, #3cb371 100%);
  color: white;
}

.header {
  text-align: center;
  margin-bottom: 30px;
}

.title {
  font-size: 28px;
  font-weight: bold;
}

.checkin-card {
  background: white;
  border-radius: 15px;
  padding: 25px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  color: #333;
  margin-bottom: 20px;
}

.streak-info {
  text-align: center;
  margin-bottom: 25px;
}

.streak-message {
  font-size: 18px;
  color: #333;
  font-weight: 500;
}

.stats-container {
  display: flex;
  justify-content: space-around;
  margin-bottom: 25px;
}

.stat-item {
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 32px;
  font-weight: bold;
  color: #667eea;
}

.stat-label {
  display: block;
  font-size: 14px;
  color: #666;
}

.checkin-button {
  width: 100%;
  padding: 15px;
  border-radius: 25px;
  border: none;
  font-size: 18px;
  font-weight: bold;
  color: white;
  margin: 20px 0;
}

.not-checked-in {
  background: linear-gradient(to right, #667eea, #764ba2);
}

.checked-in {
  background: #ccc;
  color: #666;
}

.success-animation {
  text-align: center;
  margin: 15px 0;
}

.success-text {
  font-size: 18px;
  color: #4CAF50;
  font-weight: bold;
}

.tips-section {
  background: rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 20px;
  margin-bottom: 20px;
}

.tips-title {
  font-size: 18px;
  font-weight: bold;
  margin-bottom: 10px;
  display: block;
}

.tips-list {
  font-size: 14px;
}

.tip-item {
  display: block;
  margin-bottom: 5px;
}

.buttons-container {
  display: flex;
  gap: 15px;
}

.action-button {
  flex: 1;
  padding: 12px;
  border-radius: 5px;
  font-size: 16px;
  border: none;
  color: white;
}

.achievements {
  background: #FF9800;
}

.exit {
  background: #9E9E9E;
}