<!-- pages/activities/identification-game.wxml -->
<view class="container">
  <view class="header">
    <text class="title">鸟类识别挑战</text>
    <text class="score">得分: {{score}}/{{gameBirds.length}}</text>
  </view>

  <view class="progress-container">
    <progress percent="{{(currentQuestion / gameBirds.length) * 100}}" stroke-width="6" activeColor="#4CAF50"/>
    <text class="progress-text">{{currentQuestion}} / {{gameBirds.length}}</text>
  </view>

  <block wx:if="{{gameStarted && !gameCompleted}}">
    <view class="question-container" wx:if="{{currentBird}}">
      <view class="bird-image-container">
        <image src="{{currentBird.imageUrl || '/images/default-bird.png'}}" mode="aspectFit" class="bird-image"/>
      </view>

      <view class="options-container">
        <button
          wx:for="{{options}}"
          wx:key="id"
          class="option-button {{showResult && item.commonName === correctAnswer ? 'correct' : ''}} {{showResult && item.id === userAnswer && item.commonName !== correctAnswer ? 'incorrect' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectAnswer"
          disabled="{{showResult}}"
        >
          {{item.commonName || item.species}}
        </button>
      </view>

      <view class="feedback" wx:if="{{showResult}}">
        <text>{{feedback}}</text>
      </view>
    </view>
  </block>

  <view class="completion-screen" wx:if="{{gameCompleted}}">
    <view class="completion-message">
      <text class="completion-title">挑战完成！</text>
      <text class="final-score">最终得分: {{score}}/{{gameBirds.length}}</text>
      <text class="performance">
        {{score / gameBirds.length >= 0.8 ? '太棒了！你对鸟类很了解！' :
          score / gameBirds.length >= 0.6 ? '不错！继续学习鸟类知识！' :
          '加油！多观察鸟类可以帮助提高识别能力'}}
      </text>
    </view>

    <view class="buttons-container">
      <button class="action-button restart" bindtap="restartGame">重新开始</button>
      <button class="action-button exit" bindtap="exitGame">返回首页</button>
    </view>
  </view>
</view>