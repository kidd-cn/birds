.container {
  padding: 20rpx;
  background: #f0f8f4;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 关卡头部 */
.level-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.level-info {
  display: flex;
  flex-direction: column;
}

.level-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.topic-tag {
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
}

.progress-indicator {
  background: #2e8b57;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* 题目区域 */
.question-area {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
}

.guide-box {
  background: #e8f5e9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.guide-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.question-image {
  width: 100%;
  height: 350rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

/* 完成页面 */
.complete-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
}

.confetti {
  text-align: center;
  margin-bottom: 20rpx;
}

.confetti-icon {
  font-size: 80rpx;
  animation: bounce 1s ease infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.complete-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  text-align: center;
  width: 100%;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.success-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #4caf50, #8bc34a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
}

.success-icon {
  font-size: 64rpx;
  color: #fff;
  font-weight: bold;
}

.complete-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #2e8b57;
  display: block;
  margin-bottom: 10rpx;
}

.complete-subtitle {
  font-size: 28rpx;
  color: #888;
  display: block;
  margin-bottom: 40rpx;
}

/* 分数卡片 */
.score-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.score-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.2;
}

.score-number.correct {
  color: #4caf50;
}

.score-number.total {
  color: #666;
}

.score-number.percentage {
  color: #2196f3;
}

.score-label {
  font-size: 22rpx;
  color: #888;
  margin-top: 8rpx;
}

.score-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e0e0e0;
}

/* 徽章解锁 */
.badge-unlock {
  background: linear-gradient(135deg, #fff8e1, #ffecb3);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.badge-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-icon {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.badge-info {
  display: flex;
  flex-direction: column;
  text-align: left;
}

.badge-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #f57c00;
}

.badge-desc {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

/* 操作按钮 */
.complete-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50rpx;
  padding: 28rpx 40rpx;
  font-size: 30rpx;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2e8b57, #4caf50);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(46, 139, 87, 0.3);
}

.action-btn.primary .btn-icon {
  margin-right: 10rpx;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.action-btn.secondary .btn-icon {
  margin-right: 10rpx;
}

.action-btn.achievements {
  background: linear-gradient(135deg, #ffc107, #ff9800);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.3);
}

.action-btn.achievements .btn-icon {
  margin-right: 10rpx;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}