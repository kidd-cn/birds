<!--pages/birding-spots/birding-spots.wxml-->
<view class="container">
  <view class="header">
    <text class="title">深圳代表性观鸟点</text>
    <text class="subtitle">选择您感兴趣的观鸟地点，查看该区域的鸟类分布</text>
  </view>

  <scroll-view class="spots-list" scroll-y="true">
    <view class="spot-card" wx:for="{{birdingSpots}}" wx:key="index" bindtap="selectSpot" data-spot="{{item}}">
      <view class="spot-header">
        <text class="spot-name">{{item.name}}</text>
        <text class="spot-status">{{item.special_species.length}}种明星鸟</text>
      </view>
      <view class="spot-details">
        <view class="detail-item">
          <text class="label">生态环境：</text>
          <text class="value">{{item.habitat}}</text>
        </view>
        <view class="detail-item">
          <text class="label">明星鸟种：</text>
          <text class="value">{{item.special_species.join(', ')}}</text>
        </view>
      </view>
      <view class="spot-action">
        <text class="action-btn" bindtap="viewSpotDetail" data-spot="{{item}}">查看详情</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-section">
    <button class="primary-btn" bindtap="goToMap">前往观鸟地图</button>
  </view>

  <!-- 详情模态框 -->
  <view class="detail-modal" wx:if="{{showDetailModal}}">
    <view class="modal-overlay" bindtap="closeDetailModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{currentSpotDetail.name}}</text>
        <text class="modal-close" bindtap="closeDetailModal">×</text>
      </view>
      <scroll-view class="modal-body" scroll-y="true">
        <view class="modal-section">
          <text class="section-title">简介</text>
          <text class="section-content">{{currentSpotDetail.description}}</text>
        </view>
        <view class="modal-section">
          <text class="section-title">最佳观鸟时间</text>
          <text class="section-content">{{currentSpotDetail.best_time}}</text>
        </view>
        <view class="modal-section">
          <text class="section-title">交通指南</text>
          <text class="section-content">{{currentSpotDetail.transport}}</text>
        </view>
        <view class="modal-section">
          <text class="section-title">生态环境</text>
          <text class="section-content">{{currentSpotDetail.habitat}}</text>
        </view>
        <view class="modal-section">
          <text class="section-title">明星鸟种</text>
          <view class="species-list">
            <text class="species-item" wx:for="{{currentSpotDetail.special_species}}" wx:key="index">{{item}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>