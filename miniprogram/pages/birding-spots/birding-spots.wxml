<!--pages/birding-spots/birding-spots.wxml-->
<view class="container">
  <view class="header">
    <text class="title">深圳代表性观鸟点</text>
    <text class="subtitle">选择您感兴趣的观鸟地点，查看该区域的鸟类分布</text>
  </view>

  <scroll-view class="spots-list" scroll-y="true">
    <view class="spot-card {{selectedSpot && selectedSpot.name == item.name ? 'selected' : ''}}" wx:for="{{birdingSpots}}" wx:for-index="spotIndex" wx:key="name" bindtap="selectSpot" data-index="{{spotIndex}}">
      <view class="spot-header">
        <text class="spot-name">{{item.name}}</text>
        <text class="spot-status">{{item.special_species.length}}种明星鸟</text>
      </view>
      <view class="spot-details">
        <view class="detail-item">
          <text class="label">生态环境：</text>
          <text class="value">{{item.habitat}}</text>
        </view>
        <view class="detail-item">
          <text class="label">明星鸟种：</text>
          <text class="value">{{item.special_species.join(', ')}}</text>
        </view>
        <view class="detail-item">
          <text class="label">最新观察：</text>
          <text class="value">{{item.latest_observation_date}}</text>
        </view>
      </view>
      <view class="spot-action">
        <text class="action-btn" catchtap="viewSpotDetail" data-index="{{spotIndex}}">查看详情</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-section">
    <button class="primary-btn" bindtap="goToMap">前往观鸟地图</button>
  </view>

  <!-- 详情模态框 -->
  <view class="detail-modal" wx:if="{{showDetailModal}}">
    <view class="modal-overlay" bindtap="closeDetailModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{currentSpotDetail.name}}</text>
        <text class="modal-close" bindtap="closeDetailModal">×</text>
      </view>
      <scroll-view class="modal-body" scroll-y="true">
        <view class="modal-section">
          <text class="section-title">简介</text>
          <view class="section-content">{{currentSpotDetail.description}}</view>
        </view>
        <view class="modal-section">
          <text class="section-title">最佳观鸟时间</text>
          <view class="section-content">{{currentSpotDetail.best_time}}</view>
        </view>
        <view class="modal-section">
          <text class="section-title">交通指南</text>
          <view class="section-content">{{currentSpotDetail.transport}}</view>
        </view>
        <view class="modal-section">
          <text class="section-title">生态环境</text>
          <view class="section-content">{{currentSpotDetail.habitat}}</view>
        </view>
        <view class="modal-section">
          <text class="section-title">最新观察日期</text>
          <view class="section-content">{{currentSpotDetail.latest_observation_date}}</view>
        </view>
        <view class="modal-section">
          <text class="section-title">明星鸟种</text>
          <view class="species-list">
            <text class="species-item" wx:for="{{currentSpotDetail.special_species}}" wx:key="index">{{item}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 公园详情面板 -->
  <view class="park-details" wx:if="{{showParkDetails}}">
    <!-- 顶部工具栏 -->
    <view class="top-toolbar">
      <view class="back-btn" bindtap="hideParkDetails">
        <text class="back-icon">‹</text>
        <text class="back-text">返回</text>
      </view>
    </view>

    <!-- 标签页导航 -->
    <view class="tab-nav">
      <view class="tab-item {{activeTab === 'overview' ? 'active' : ''}}" bindtap="switchTab" data-tab="overview">
        <text>概览</text>
      </view>
      <view class="tab-item {{activeTab === 'birds' ? 'active' : ''}}" bindtap="switchTab" data-tab="birds">
        <text>鸟类</text>
      </view>
      <view class="tab-item {{activeTab === 'ecology' ? 'active' : ''}}" bindtap="switchTab" data-tab="ecology">
        <text>生态环境</text>
      </view>
    </view>

    <!-- 标签页内容 -->
    <view class="tab-content">
      <!-- 概览标签内容 -->
      <view class="tab-pane" wx:if="{{activeTab === 'overview'}}">
        <view class="overview-section">
          <text class="section-title">{{selectedSpot.name}}</text>
          <view class="info-item">
            <text class="info-label">位置：</text>
            <text class="info-value">{{selectedSpot.location}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">面积：</text>
            <text class="info-value">{{selectedSpot.area || '未知'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">开放时间：</text>
            <text class="info-value">{{selectedSpot.openingHours || '详见公园公告'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">交通：</text>
            <text class="info-value">{{selectedSpot.transportation || '未提供'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">特色：</text>
            <text class="info-value">{{selectedSpot.features || '未提供'}}</text>
          </view>
        </view>
      </view>

      <!-- 鸟类标签内容 -->
      <view class="tab-pane" wx:if="{{activeTab === 'birds'}}">
        <view class="birds-section">
          <text class="section-title">常见鸟种</text>
          <view class="bird-list">
            <view class="bird-item" wx:for="{{selectedSpot.birds}}" wx:key="species">
              <text class="bird-name">{{item.commonName || item.species}}</text>
              <text class="bird-scientific">{{item.scientificName}}</text>
            </view>
          </view>
          <view class="info-item">
            <text class="info-label">最佳观鸟时间：</text>
            <text class="info-value">{{selectedSpot.bestBirdingTime || '未提供'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">观鸟热点：</text>
            <text class="info-value">{{selectedSpot.hotspots || '未提供'}}</text>
          </view>
        </view>
      </view>

      <!-- 生态环境标签内容 -->
      <view class="tab-pane" wx:if="{{activeTab === 'ecology'}}">
        <view class="ecology-section">
          <text class="section-title">生态环境</text>
          <view class="info-item">
            <text class="info-label">栖息环境：</text>
            <text class="info-value">{{selectedSpot.ecology.habitat || '未提供'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">植被类型：</text>
            <text class="info-value">{{selectedSpot.ecology.vegetation || '未提供'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">季节特征：</text>
            <text class="info-value">{{selectedSpot.ecology.seasonalFeatures || '未提供'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">保护状况：</text>
            <text class="info-value">{{selectedSpot.ecology.conservationStatus || '未提供'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>