/* pages/birding-spots/birding-spots.wxss */
page {
  background-color: var(--bg-page, #e8f4ec);
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: var(--bg-page, #e8f4ec);
}

.header {
  padding: 30rpx 0;
  text-align: center;
  border-bottom: 1rpx solid var(--border-light, #eeeeee);
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary, #333333);
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary, #666666);
}

.spots-list {
  flex: 1;
  margin: 20rpx 0;
}

.spot-card {
  background-color: var(--bg-card, #ffffff);
  border-radius: var(--radius-card, 15rpx);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card, 0 4rpx 12rpx rgba(0, 0, 0, 0.05));
  transition: all 0.3s ease;
}

.spot-card.selected {
  border: 3rpx solid #007AFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.3);
  background-color: #f0f8ff;
}

.spot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.spot-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.spot-status {
  font-size: 24rpx;
  color: #007AFF;
  background-color: #f0f8ff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.spot-details {
  margin-bottom: 25rpx;
}

.detail-item {
  display: flex;
  margin-bottom: 15rpx;
}

.label {
  font-size: 26rpx;
  color: #666;
  min-width: 140rpx;
}

.value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.spot-action {
  text-align: right;
}

.action-btn {
  font-size: 26rpx;
  color: #007AFF;
  border: 1rpx solid #007AFF;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.bottom-section {
  padding: 30rpx 0;
}

.primary-btn {
  background-color: #007AFF;
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

/* 详情模态框样式 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  background-color: var(--bg-card, #ffffff);
  border-radius: var(--radius-card, 15rpx);
  width: 90%;
  max-height: 80%;
  overflow: hidden;
  z-index: 1001;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 10rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 20rpx 30rpx;
  max-height: 60vh;
}

.modal-section {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.section-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.species-list {
  display: flex;
  flex-wrap: wrap;
}

.species-item {
  display: inline-block;
  font-size: 24rpx;
  color: #007AFF;
  background-color: #f0f8ff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin: 5rpx;
}