/* pages/birding-spots/birding-spots.wxss */
page {
  background-color: var(--bg-page);
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: var(--bg-page);
}

.header {
  padding: 30rpx 0;
  text-align: center;
  border-bottom: 1rpx solid var(--border-light);
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.spots-list {
  flex: 1;
  margin: 20rpx 0;
}

.spot-card {
  background-color: var(--bg-card);
  border-radius: var(--radius-card);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  transition: all 0.3s ease;
}

.spot-card.selected {
  border: 3rpx solid var(--primary-green);
  box-shadow: 0 4rpx 16rpx rgba(46, 139, 87, 0.3);
  background-color: var(--bg-card-alt);
}

.spot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.spot-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.spot-status {
  font-size: 24rpx;
  color: var(--primary-green);
  background-color: var(--bg-card-alt);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.spot-details {
  margin-bottom: 25rpx;
}

.detail-item {
  display: flex;
  margin-bottom: 15rpx;
}

.label {
  font-size: 26rpx;
  color: var(--text-secondary);
  min-width: 140rpx;
}

.value {
  font-size: 26rpx;
  color: var(--text-primary);
  flex: 1;
  word-break: break-all;
}

.spot-action {
  text-align: right;
}

.action-btn {
  font-size: 26rpx;
  color: var(--primary-green);
  border: 1rpx solid var(--primary-green);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.bottom-section {
  padding: 30rpx 0;
}

.primary-btn {
  background-color: var(--primary-green);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

/* 详情模态框样式 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  background-color: var(--bg-card);
  border-radius: var(--radius-card);
  width: 90%;
  max-width: 680rpx;
  max-height: 85%;
  overflow: hidden;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 10rpx;
  border-bottom: 1rpx solid var(--border-light);
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-muted);
  line-height: 1;
}

.modal-body {
  flex: 1;
  min-height: 0;
  height: 60vh;
  padding: 20rpx 30rpx 30rpx;
  box-sizing: border-box;
}

.modal-section {
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.section-content {
  display: block;
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  word-wrap: break-word;
  word-break: break-word;
  white-space: normal;
  text-align: justify; /* 设置为两端对齐 */
  text-justify: inter-word; /* 调整单词间距以实现更好的对齐 */
}

.species-list {
  display: flex;
  flex-wrap: wrap;
}

.species-item {
  display: inline-block;
  font-size: 24rpx;
  color: var(--primary-green);
  background-color: var(--bg-card-alt);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin: 5rpx;
}

/* 评级星星样式 */
.rating-stars {
  display: flex;
  flex-direction: row;
}

.star {
  font-size: 28rpx;
  margin-left: 10rpx;
}

.star.filled {
  color: gold;
}

.star.empty {
  color: #ddd;
}

.rating-display {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 10rpx;
}

.rating-text {
  margin-left: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.rating-display-large {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 30rpx 0;
}

.large-star {
  font-size: 36rpx;
  margin-right: 5rpx;
}

.large-star.filled {
  color: gold;
}

.large-star.empty {
  color: #ddd;
}

.rating-text-large {
  font-size: 28rpx;
  color: #666;
  margin-left: 10rpx;
  font-weight: bold;
}

/* 公园详情面板样式 */
.park-details {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: white;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-top: 20px;
  padding-bottom: 40px;
}

/* 顶部工具栏样式 */
.top-toolbar {
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  background: white;
  border-bottom: 1px solid #e0e0e0;
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
}

.back-icon {
  font-size: 36rpx;
  color: #666;
  margin-right: 10rpx;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

/* 标签页导航样式 */
.tab-nav {
  display: flex;
  height: 80rpx;
  background: #f5f5f5;
  border-bottom: 1px solid #e0e0e0;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #2e8b57;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #2e8b57;
  border-radius: 3rpx;
}

/* 标签页内容样式 */
.tab-content {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.tab-pane {
  min-height: 100%;
}

/* 内容区域样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
}

.info-item {
  display: flex;
  margin: 20rpx 0;
  font-size: 28rpx;
  line-height: 1.6;
}

.info-label {
  color: #666;
  min-width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  color: #333;
  flex: 1;
  word-wrap: break-word;
}

.overview-section, .birds-section, .ecology-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.bird-list {
  margin: 20rpx 0;
}

.bird-item {
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.bird-item:last-child {
  border-bottom: none;
}

.bird-name {
  font-weight: bold;
  color: #333;
  display: block;
}

.bird-scientific {
  font-size: 24rpx;
  color: #666;
  display: block;
  font-style: italic;
}