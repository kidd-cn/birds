/* pages/index/index.wxss */
page {
  height: 100%;
  background-color: #f5f5f5;
}

.map-container {
  width: 100%;
  height: 100vh;
}

.bird-additional-info {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.info-item {
  display: flex;
  margin: 10rpx 0;
  font-size: 24rpx;
}

.info-label {
  color: #666;
  min-width: 160rpx;
}

.info-value {
  color: #333;
  flex: 1;
}