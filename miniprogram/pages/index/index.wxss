/* pages/index/index.wxss */
page {
  height: 100%;
  background-color: var(--bg-page, #e8f4ec);
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  justify-content: flex-start;
  align-items: stretch;
  box-sizing: border-box;
  background-color: var(--bg-page, #e8f4ec);
}

.map-container {
  flex: 1;
  width: 100%;
  min-height: 0;
}

.bird-image {
  width: 100%;
  max-height: 50vh; /* Allow image to take up to 50% of screen height */
  min-height: 200rpx; /* Ensure minimum visibility */
  object-fit: cover; /* Crop image to fill space while maintaining aspect ratio */
  display: block;
  margin: 20rpx auto;
}

.bird-detail-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  max-height: 85vh;
  background: var(--bg-card, #ffffff);
  border-radius: var(--radius-card, 15rpx) var(--radius-card, 15rpx) 0 0;
  padding: 40rpx 30rpx calc(30rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  z-index: 1000;
  box-sizing: border-box;
  box-shadow: var(--shadow-card, 0 4rpx 12rpx rgba(0, 0, 0, 0.05));
}

.bird-detail-header {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-light, #eeeeee);
}

.bird-detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary, #333333);
}

.bird-detail-close {
  position: absolute;
  right: 0;
  top: 0;
  font-size: 40rpx;
  color: var(--text-muted, #999999);
  background: none;
  border: none;
  padding: 10rpx;
}

.bird-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin: 20rpx 0;
  text-align: center;
}

.bird-scientific-name {
  font-size: 24rpx;
  color: #666;
  font-style: italic;
  margin: 10rpx 0;
  text-align: center;
}

.bird-description {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  margin: 20rpx 0;
  text-align: justify;
}

.bird-additional-info {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.info-item {
  display: flex;
  margin: 10rpx 0;
  font-size: 24rpx;
}

.info-label {
  color: #666;
  min-width: 160rpx;
}

.info-value {
  color: #333;
  flex: 1;
  word-wrap: break-word;
}