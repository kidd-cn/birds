/* pages/index/index.wxss */
page {
  height: 100%;
  background-color: var(--bg-page);
}

.activity-entry-button {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  z-index: 999;
  background-color: var(--primary-green);
  color: white;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(46, 139, 87, 0.2); /* Match theme color */
  border: none;
  min-width: 180rpx;
  text-align: center;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-entry {
  position: absolute;
  top: 40rpx;
  right: 250rpx;
  z-index: 10;
}

.activity-entry-button:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(46, 139, 87, 0.3);
  background-color: var(--secondary-green);
}

.activity-entry-button::after {
  border: none;
}

/* Focus styles for accessibility */
.activity-entry-button:focus {
  outline: 4rpx solid var(--accent-green);
  outline-offset: 2rpx;
}

/* Responsive adjustments for smaller screens */
@media (max-width: 375px) {
  .activity-entry-button {
    top: 20rpx;
    right: 20rpx;
    min-width: 160rpx;
    padding: 16rpx 20rpx;
    font-size: 26rpx;
  }
}

/* Additional activity-related styles */
.activity-section {
  margin: 20rpx;
  padding: 20rpx;
  background-color: var(--bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}

.activity-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: var(--bg-card-alt);
  border-radius: var(--radius-card);
  border-left: 6rpx solid var(--primary-green);
}

.activity-item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
  background-color: var(--primary-green);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: bold;
}

.activity-item-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  justify-content: flex-start;
  align-items: stretch;
  box-sizing: border-box;
  background-color: var(--bg-page);
}

.map-container {
  flex: 1;
  width: 100%;
  min-height: 0;
}

.bird-image-container {
  width: 100%;
  display: flex;
  justify-content: center;
  margin: 20rpx 0;
}

.bird-image {
  width: 100%;
  max-height: 50vh; /* Allow image to take up to 50% of screen height */
  min-height: 200rpx; /* Ensure minimum visibility */
  object-fit: cover; /* Crop image to fill space while maintaining aspect ratio */
  display: block;
  margin: 0 auto;
  border-radius: 10rpx;
}

/* 添加点击态效果 */
.bird-image-container:active {
  opacity: 0.8;
}

.bird-detail-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  max-height: 85vh;
  background: var(--bg-card);
  border-radius: var(--radius-card) var(--radius-card) 0 0;
  padding: 40rpx 30rpx calc(30rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  z-index: 1000;
  box-sizing: border-box;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
}

.bird-detail-header {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-light);
  flex-shrink: 0;
}

.bird-detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.bird-detail-close {
  position: absolute;
  right: 0;
  top: 0;
  font-size: 40rpx;
  color: var(--text-muted);
  background: none;
  border: none;
  padding: 10rpx;
}

.bird-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin: 20rpx 0;
  text-align: center;
  flex-shrink: 0;
}

.bird-scientific-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-style: italic;
  margin: 10rpx 0;
  text-align: center;
  flex-shrink: 0;
}

.bird-description {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  margin: 20rpx 0;
  text-align: justify; /* 设置为两端对齐 */
  text-justify: inter-word; /* 调整单词间距以实现更好的对齐 */
  flex: 1;
  min-height: 0;
  overflow-y: auto;
}

.bird-additional-info {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-light);
  flex-shrink: 0;
}

.info-item {
  display: flex;
  margin: 10rpx 0;
  font-size: 24rpx;
}

.info-label {
  color: var(--text-secondary);
  min-width: 160rpx;
}

.info-value {
  color: var(--text-primary);
  flex: 1;
  word-wrap: break-word;
}