/* pages/index/index.wxss */
page {
  height: 100%;
  background: linear-gradient(135deg, #e0f7fa 0%, #f5fcff 100%);
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.custom-nav-bar {
  height: 88rpx;
  background: linear-gradient(90deg, #4CAF50, #2E7D32);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.2);
  z-index: 999;
  position: relative;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.map-container {
  flex: 1;
  width: 100%;
}

.bird-image {
  width: 100%;
  max-height: 35vh;
  min-height: 180rpx;
  object-fit: cover;
  display: block;
  margin: 20rpx auto;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.bird-detail-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to bottom, #ffffff 0%, #f9f9f9 100%);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 30rpx 60rpx;
  max-height: 85vh;
  overflow-y: auto;
  z-index: 1000;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.15);
}

.bird-detail-header {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.bird-detail-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #2c3e50;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.bird-detail-close {
  position: absolute;
  right: 0;
  top: 0;
  font-size: 48rpx;
  color: #bdc3c7;
  background: none;
  border: none;
  padding: 10rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.bird-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  margin: 15rpx 0;
  text-align: center;
  background: linear-gradient(135deg, #3498db, #2980b9);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.bird-scientific-name {
  font-size: 26rpx;
  color: #7f8c8d;
  font-style: italic;
  margin: 10rpx 0;
  text-align: center;
}

.bird-description {
  font-size: 28rpx;
  color: #34495e;
  line-height: 1.7;
  margin: 20rpx 0;
  text-align: justify;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border-left: 6rpx solid #4CAF50;
}

.bird-additional-info {
  margin-top: 25rpx;
  padding-top: 25rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: inset 0 0 10rpx rgba(0,0,0,0.03);
}

.info-item {
  display: flex;
  margin: 15rpx 0;
  font-size: 26rpx;
  padding: 10rpx 0;
}

.info-label {
  color: #3498db;
  min-width: 180rpx;
  font-weight: 500;
}

.info-value {
  color: #2c3e50;
  flex: 1;
  word-wrap: break-word;
  font-weight: 400;
}