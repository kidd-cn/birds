/* pages/navigation/navigation.wxss */
page {
  background-color: var(--bg-page, #e8f4ec);
  height: 100%;
}

.container {
  padding: 40rpx;
  height: 100%;
  box-sizing: border-box;
  background-color: var(--bg-page, #e8f4ec);
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 150rpx;
  height: 150rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary, #333333);
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary, #666666);
}

.features {
  margin-bottom: 50rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  background-color: var(--bg-card, #ffffff);
  border-radius: var(--radius-card, 15rpx);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card, 0 4rpx 12rpx rgba(0, 0, 0, 0.05));
}

.card-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 60rpx;
  text-align: center;
}

.card-content {
  flex: 1;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary, #333333);
  margin-bottom: 10rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary, #666666);
  line-height: 1.5;
}

.card-arrow {
  font-size: 40rpx;
  color: #ccc;
}

.intro {
  background-color: var(--bg-card, #ffffff);
  border-radius: var(--radius-card, 15rpx);
  padding: 30rpx;
  box-shadow: var(--shadow-card, 0 4rpx 12rpx rgba(0, 0, 0, 0.05));
}

.intro-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary, #333333);
  margin-bottom: 20rpx;
}

.intro-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary, #666666);
  line-height: 1.6;
}