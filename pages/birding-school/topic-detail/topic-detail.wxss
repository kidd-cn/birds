.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.topic-header {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.topic-image {
  width: 100%;
  height: 300rpx;
}

.topic-info {
  padding: 20rpx;
}

.topic-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.topic-desc {
  font-size: 28rpx;
  color: #666;
  display: block;
}

.levels-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.levels-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}